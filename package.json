{
  "name": "synchub-api",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "swc src -d dist --strip-leading-paths --ignore '**/*.d.ts'",
    "typecheck": "tsc --noEmit",
    "start": "node dist/app.js",
    "db:login": "npx supabase login",
    "db:init": "npx supabase init",
    "db:link": "npx supabase link",
    "db:push": "npx supabase db push",
    "db:reset": "npx supabase db reset",
    "db:migration:new": "npx supabase migration new",
    "db:migration:list": "npx supabase migration list",
    "db:migration:up": "npx supabase migration up",
    "db:migration:down": "npx supabase migration repair --status reverted",
    "db:diff": "npx supabase db diff",
    "db:status": "npx supabase db status",
    "db:setup": "bash scripts/db-setup.sh"
  },
  "dependencies": {
    "@koa/bodyparser": "^6.1.0",
    "@koa/cors": "^5.0.0",
    "@koa/multer": "^4.0.0",
    "@koa/router": "^15.4.0",
    "@supabase/supabase-js": "^2.49.1",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "koa": "3",
    "multer": "^2.1.1",
    "winston": "^3.19.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@types/koa": "^3.0.1",
    "@types/koa__cors": "^5.0.1",
    "@types/koa__router": "^12.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
