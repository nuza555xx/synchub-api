{
  "info": {
    "name": "syncHub API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "syncHub — Social Media Management Platform API"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "socialAccountId",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/signup",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"securePassword123\"\n}"
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('userId', res.result.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"securePassword123\"\n}"
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', res.data.access_token);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refresh_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', res.result.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.result.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Social Accounts",
      "item": [
        {
          "name": "Connect TikTok",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/social-accounts/connect/tiktok",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"redirectUri\": \"http://localhost:3000/social-accounts/callback/tiktok\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  console.log('Auth URL:', res.result.authUrl);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Callback TikTok",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/social-accounts/callback/tiktok?code=AUTH_CODE_HERE&state=STATE_HERE",
              "host": ["{{baseUrl}}"],
              "path": ["social-accounts", "callback", "tiktok"],
              "query": [
                {
                  "key": "code",
                  "value": "AUTH_CODE_HERE"
                },
                {
                  "key": "state",
                  "value": "STATE_HERE"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('socialAccountId', res.result.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Social Accounts",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/social-accounts"
          }
        },
        {
          "name": "Get Account Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/social-accounts/{{socialAccountId}}/health"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/social-accounts/{{socialAccountId}}/refresh-token"
          }
        },
        {
          "name": "Disconnect Account",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/social-accounts/{{socialAccountId}}"
          }
        }
      ]
    }
  ]
}
